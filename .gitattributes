# Keep text files stable across Windows/macOS/Linux
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf

# Office/PDF/images/media are binary; never normalize line endings
*.pdf binary
*.doc binary
*.docx binary
*.hwp binary
*.hwpx binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.mp3 binary
*.mp4 binary
*.wav binary
